---
interface Props {
  url: string;
  title: string;
  summary?: string;
  tags?: string[];
  kind?: 'idea' | 'post';
}
const { url, title, summary, tags = [], kind = 'post' } = Astro.props;

// X intent text: title + up to 3 hashtags. Each hashtag has spaces stripped.
// X counts URLs as 23 chars regardless of length, so we budget ~250 chars for text.
const hashtags = tags
  .slice(0, 3)
  .map(t => '#' + t.replace(/\s+/g, ''))
  .join(' ');
const xText = hashtags ? `${title} ${hashtags}` : title;

const encodedUrl = encodeURIComponent(url);
const encodedXText = encodeURIComponent(xText);
const encodedTitle = encodeURIComponent(title);

const targets = [
  { id: 'x',        label: 'X',        ariaLabel: 'Share on X (formerly Twitter)', href: `https://x.com/intent/post?url=${encodedUrl}&text=${encodedXText}` },
  { id: 'facebook', label: 'FB',       ariaLabel: 'Share on Facebook',             href: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}` },
  { id: 'linkedin', label: 'LINKEDIN', ariaLabel: 'Share on LinkedIn',             href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}&title=${encodedTitle}` },
  { id: 'line',     label: 'LINE',     ariaLabel: 'Share on LINE',                 href: `https://social-plugins.line.me/lineit/share?url=${encodedUrl}` },
];

const heading = kind === 'idea' ? '▶ SHARE THIS QUEST' : '▶ SHARE THIS PATCH';
---
<section class="share-block" aria-label="Share">
  <div class="share-head">
    <span class="lab">{heading}</span>
    <span class="hint">// signal-boost via ally</span>
  </div>
  <div class="share-row">
    <button
      class="share-btn native"
      type="button"
      data-share-native
      data-url={url}
      data-title={title}
      data-text={summary ?? ''}
      aria-label="Open native share sheet"
      hidden
    >
      ▶ SHARE
    </button>
    {targets.map(t => (
      <a
        class={`share-btn share-${t.id}`}
        href={t.href}
        target="_blank"
        rel="noopener noreferrer"
        data-platform={t.id}
        aria-label={t.ariaLabel}
      >
        {t.label}
      </a>
    ))}
    <button class="share-btn copy" type="button" data-share-copy data-url={url} aria-label="Copy link to clipboard">
      ▷ COPY LINK
    </button>
  </div>
</section>

<style>
  .share-block {
    margin: 32px 0 36px;
    padding: 16px 20px;
    background: var(--parchment);
    border: 2px solid var(--ink);
    box-shadow: 4px 4px 0 0 var(--ink);
  }
  .share-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }
  .share-head .lab {
    font-family: var(--font-pixel);
    font-size: 11px;
    color: var(--ink);
    letter-spacing: 1px;
  }
  .share-head .hint {
    font-family: var(--font-mono);
    color: var(--muted);
    font-size: 14px;
  }
  .share-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .share-btn {
    font-family: var(--font-pixel);
    font-size: 10px;
    line-height: 1;
    padding: 11px 14px;
    border: 2px solid var(--ink);
    background: var(--parchment-deep);
    color: var(--ink);
    text-decoration: none;
    cursor: pointer;
    letter-spacing: 1px;
    transition: transform 0.06s ease-out, box-shadow 0.06s ease-out, background 0.12s;
    box-shadow: 2px 2px 0 0 var(--ink);
  }
  .share-btn:hover {
    background: var(--yellow);
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0 0 var(--ink);
  }
  .share-btn:active {
    transform: translate(1px, 1px);
    box-shadow: 0 0 0 0 var(--ink);
  }
  .share-btn:focus-visible {
    outline: 2px dashed var(--orange);
    outline-offset: 2px;
  }
  .share-btn.native {
    background: var(--mint);
    color: var(--ink);
  }
  .share-btn.native:hover { background: var(--yellow); }
  .share-btn.copy {
    background: var(--orange);
    color: var(--parchment);
  }
  .share-btn.copy:hover { background: var(--yellow); color: var(--ink); }
  .share-btn.copy.copied { background: var(--mint); color: var(--ink); }
  .share-btn.copy.failed { background: var(--pink); color: var(--parchment); }
  @media (max-width: 640px) {
    .share-btn { font-size: 9px; padding: 9px 11px; }
    .share-block { padding: 14px 14px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .share-btn { transition: none; }
    .share-btn:hover, .share-btn:active { transform: none; }
  }
</style>

<script>
  type Gtag = (...args: unknown[]) => void;
  const gtag = (): Gtag | undefined =>
    (window as unknown as { gtag?: Gtag }).gtag;

  // ---- Native Web Share API (mobile / Safari) ----
  // Reveal the [▶ SHARE] button only when the API exists.
  document.querySelectorAll<HTMLButtonElement>('[data-share-native]').forEach(btn => {
    if (typeof navigator !== 'undefined' && typeof navigator.share === 'function') {
      btn.hidden = false;
    }
    btn.addEventListener('click', async () => {
      const url = btn.dataset.url ?? '';
      const title = btn.dataset.title ?? '';
      const text = btn.dataset.text ?? '';
      try {
        await navigator.share({ title, text, url });
        gtag()?.('event', 'share', { method: 'native', content_type: 'page', item_id: url });
      } catch (err) {
        // AbortError = user dismissed the sheet, silent. Other errors: log only.
        if ((err as DOMException)?.name !== 'AbortError') console.warn('native share failed', err);
      }
    });
  });

  // ---- Copy link with progressive fallback ----
  const flashState = (btn: HTMLButtonElement, original: string, label: string, cls: string) => {
    btn.textContent = label;
    btn.classList.add(cls);
    setTimeout(() => {
      btn.textContent = original;
      btn.classList.remove(cls);
    }, 2000);
  };

  const legacyCopy = (text: string): boolean => {
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.setAttribute('readonly', '');
    ta.style.position = 'fixed';
    ta.style.top = '-9999px';
    document.body.appendChild(ta);
    ta.select();
    let ok = false;
    try { ok = document.execCommand('copy'); } catch { ok = false; }
    document.body.removeChild(ta);
    return ok;
  };

  document.querySelectorAll<HTMLButtonElement>('[data-share-copy]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.url;
      if (!url) return;
      const original = btn.textContent ?? '▷ COPY LINK';
      let ok = false;
      if (navigator.clipboard && window.isSecureContext) {
        try {
          await navigator.clipboard.writeText(url);
          ok = true;
        } catch { ok = false; }
      }
      if (!ok) ok = legacyCopy(url);
      if (ok) {
        flashState(btn, original, '✓ COPIED!', 'copied');
        gtag()?.('event', 'share', { method: 'copy_link', content_type: 'page', item_id: url });
      } else {
        flashState(btn, original, '✗ FAILED', 'failed');
      }
    });
  });

  // ---- Platform-anchor analytics ----
  document.querySelectorAll<HTMLAnchorElement>('.share-btn[data-platform]').forEach(a => {
    a.addEventListener('click', () => {
      gtag()?.('event', 'share', { method: a.dataset.platform, content_type: 'page', item_id: a.href });
    });
  });
</script>
