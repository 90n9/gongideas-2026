---
import { getCollection, getEntry, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TalkToBulby from '../../components/TalkToBulby.astro';
import ShareButtons from '../../components/ShareButtons.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const sorted = [...posts].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return sorted.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: sorted[i + 1] ?? null,
      next: sorted[i - 1] ?? null,
    },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
  prev: CollectionEntry<'blog'> | null;
  next: CollectionEntry<'blog'> | null;
}
const { post, prev, next } = Astro.props;
const { Content } = await render(post);
const { data, id } = post;

const dateStr = data.date.toISOString().slice(0, 10).replace(/-/g, '.');

let related: CollectionEntry<'ideas'> | null = null;
if (data.relatedIdea) {
  related = (await getEntry('ideas', data.relatedIdea)) ?? null;
}

const canonicalImage = data.heroImage ?? '/og-default.png';
const siteOrigin = Astro.site ?? new URL('https://gongideas.com/');
const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: data.title,
  description: data.summary,
  datePublished: data.date.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Narathip Harijiratiwong',
    url: new URL('/about/', siteOrigin).href,
  },
  image: new URL(canonicalImage, siteOrigin).href,
  keywords: data.tags.join(', '),
  inLanguage: 'en',
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': new URL(`/blog/${id}/`, siteOrigin).href,
  },
};
---
<BaseLayout
  title={data.title}
  description={data.summary}
  active="blog"
  image={canonicalImage}
  type="article"
  publishDate={data.date}
  structuredData={blogJsonLd}
>

  <section class="idea-hero">
    <div class="container">
      <div class="idea-breadcrumb">
        <a href="/blog/">BLOG</a> &nbsp;/&nbsp; {id.toUpperCase().replace(/-/g, '_')}.MD
      </div>

      <article class="post-shell">
        <div class="term-bar">
          <div class="term-dots">
            <span class="r"></span><span class="y"></span><span class="g"></span>
          </div>
          <span style="color: var(--mint);">gong@ideas:~/blog$ cat {id}.md</span>
          <span class="meta-end" style="color: var(--muted);">UTF-8 · 80x24</span>
        </div>

        <header class="head-block">
          <div class="post-date">▶ {dateStr}</div>
          <h1>{data.title}</h1>
          <p class="post-summary">{data.summary}</p>
          <div class="post-tags">
            {data.tags.map(t => <span class="tag">#{t}</span>)}
          </div>
        </header>

        <div class="body-block">
          <div class="prose">
            <Content />
          </div>
        </div>
      </article>

      <ShareButtons
        url={new URL(`/blog/${id}/`, siteOrigin).href}
        title={data.title}
        summary={data.summary}
        tags={data.tags}
        kind="post"
      />

      {related && (
        <a class="entry-nav-card" href={`/ideas/${related.id}/`} style="display: block; margin-bottom: 32px;">
          <div class="lab">▶ RELATED IDEA · #{related.data.ideaId}</div>
          <div class="title">{related.data.title}</div>
        </a>
      )}

      <nav class="entry-nav" aria-label="Post navigation">
        {prev ? (
          <a class="entry-nav-card prev" href={`/blog/${prev.id}/`}>
            <div class="lab">◀ PREV ENTRY</div>
            <div class="title">{prev.data.title}</div>
          </a>
        ) : <div></div>}
        {next ? (
          <a class="entry-nav-card next" href={`/blog/${next.id}/`}>
            <div class="lab">NEXT ENTRY ▶</div>
            <div class="title">{next.data.title}</div>
          </a>
        ) : <div></div>}
      </nav>
    </div>
  </section>

  <TalkToBulby />

</BaseLayout>

<script>
  document.querySelectorAll('.prose pre').forEach(pre => {
    const btn = document.createElement('button');
    btn.className = 'copy-btn';
    btn.textContent = 'COPY';
    btn.addEventListener('click', () => {
      const code = pre.querySelector('code');
      const text = (code ?? pre).textContent ?? '';
      navigator.clipboard.writeText(text).then(() => {
        btn.textContent = 'COPIED!';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = 'COPY';
          btn.classList.remove('copied');
        }, 2000);
      });
    });
    pre.appendChild(btn);
  });
</script>
